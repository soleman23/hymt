<section class="newsletter" id="newsletter">
  <div>
    <h2 class="newsletter__title">Travel insights.<br>Delivered quietly.</h2>
    <p class="newsletter__body">
      Destination notes, shoulder-season tips, and the occasional
      remarkable find. No spam, no urgency. Unsubscribe whenever.
    </p>
  </div>
  <div>
    <form class="newsletter__form" action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
      <input type="hidden" name="subject" value="Newsletter signup — hymtravel.com" />
      <input type="hidden" name="from_name" value="HYM Travel Website" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
      <input type="email" name="email" class="newsletter__input" placeholder="Your email address" required aria-label="Email address">
      <button type="submit" class="newsletter__submit">Subscribe</button>
    </form>
    <p class="newsletter__fine">By subscribing you agree to receive occasional emails from Hit Your Mark Travel. Unsubscribe anytime.</p>
  </div>
</section>
